# ─────────────────────────────────────────────────────────────
# ClipForge AI — environment template
# Copy to `.env` at the repo root AND into apps/web/.env.local (NEXT_PUBLIC_* vars)
# Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ---- Core ----
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---- PostgreSQL ----
# Local docker default. In prod use Supabase's Postgres connection string.
DATABASE_URL=postgresql://clipforge:clipforge@localhost:5432/clipforge

# ---- Supabase (Auth + Storage) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key       # server-only, NEVER expose to the browser
SUPABASE_STORAGE_BUCKET=clipforge-media
# JWT secret from Supabase (Settings → API → JWT Secret) — used by the API to verify user tokens
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Frontend needs the public pair (also place these in apps/web/.env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- AI provider ----
# Groq (https://console.groq.com) is free and needs NO credit card. When set,
# it is used for transcription (Whisper) and analysis (Llama) instead of OpenAI.
GROQ_API_KEY=gsk_...
# OpenAI is the fallback (requires a card). Leave blank if using Groq.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
GROQ_TRANSCRIBE_MODEL=whisper-large-v3
GROQ_ANALYSIS_MODEL=llama-3.3-70b-versatile

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- FFmpeg ----
# Leave blank to use the ffmpeg-static binary bundled via npm.
FFMPEG_PATH=
FFPROBE_PATH=

# ---- App limits ----
FREE_PLAN_VIDEOS_PER_MONTH=3
MAX_UPLOAD_MB=2048

# ---- Admin ----
# Comma-separated list of user emails granted admin-panel access.
ADMIN_EMAILS=you@example.com
